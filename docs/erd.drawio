<mxfile host="app.diagrams.net">
  <diagram id="subject-only-erd" name="Subject-only ERD">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1600" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="users" value="users&#xa;_id, role, username&#xa;email, isActive" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#EFF6FF;strokeColor=#2563EB;fontStyle=1" vertex="1" parent="1"><mxGeometry x="80" y="120" width="220" height="100" as="geometry"/></mxCell>
        <mxCell id="subjects" value="subjects&#xa;_id, code, name&#xa;isActive" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#ECFDF5;strokeColor=#059669;fontStyle=1" vertex="1" parent="1"><mxGeometry x="420" y="120" width="220" height="100" as="geometry"/></mxCell>
        <mxCell id="assignments" value="subjectassignments&#xa;subjectId, teacherId, assignedBy&#xa;assignedAt, removedAt, status" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFF7ED;strokeColor=#EA580C;fontStyle=1" vertex="1" parent="1"><mxGeometry x="210" y="310" width="300" height="110" as="geometry"/></mxCell>
        <mxCell id="documents" value="documents&#xa;subjectId, uploadedBy&#xa;status: uploaded | processing | ready | failed" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#F5F3FF;strokeColor=#7C3AED;fontStyle=1" vertex="1" parent="1"><mxGeometry x="760" y="120" width="300" height="110" as="geometry"/></mxCell>
        <mxCell id="chunks" value="chunks&#xa;documentId, content, embedding" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#F8FAFC;strokeColor=#475569;fontStyle=1" vertex="1" parent="1"><mxGeometry x="800" y="330" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="chats" value="chatsessions&#xa;userId, documentId, messages" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FDF2F8;strokeColor=#DB2777;fontStyle=1" vertex="1" parent="1"><mxGeometry x="1110" y="120" width="240" height="100" as="geometry"/></mxCell>
        <mxCell id="usage" value="questionquotas&#xa;userId, periodKey, questionCount" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FEFCE8;strokeColor=#CA8A04;fontStyle=1" vertex="1" parent="1"><mxGeometry x="80" y="510" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="emails" value="emailnotifications&#xa;event, recipientEmail&#xa;status, attempts, nextAttemptAt" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#EEF2FF;strokeColor=#4F46E5;fontStyle=1" vertex="1" parent="1"><mxGeometry x="410" y="510" width="290" height="100" as="geometry"/></mxCell>
        <mxCell id="audits" value="auditlogs&#xa;actorId, action, entityId&#xa;metadata, createdAt" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#F0FDFA;strokeColor=#0D9488;fontStyle=1" vertex="1" parent="1"><mxGeometry x="760" y="510" width="280" height="100" as="geometry"/></mxCell>
        <mxCell id="e1" value="teacherId / assignedBy" edge="1" parent="1" source="users" target="assignments" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="subjectId" edge="1" parent="1" source="subjects" target="assignments" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="subjectId" edge="1" parent="1" source="subjects" target="documents" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="uploadedBy" edge="1" parent="1" source="users" target="documents" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="documentId" edge="1" parent="1" source="documents" target="chunks" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="documentId" edge="1" parent="1" source="documents" target="chats" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="userId" edge="1" parent="1" source="users" target="chats" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="userId" edge="1" parent="1" source="users" target="usage" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="actorId" edge="1" parent="1" source="users" target="audits" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="entityId" edge="1" parent="1" source="documents" target="audits" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
