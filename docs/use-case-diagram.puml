@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam shadowing false

actor Admin
actor Teacher
actor Student
actor "Gemini API" as Gemini
database MongoDB as Mongo

rectangle "Smart RAG Learning Platform" {
  package "Academic Administration" {
    usecase "Manage users and subjects" as UC_ManageCatalog
    usecase "Manage classes and roster" as UC_ManageClasses
    usecase "Join class by code" as UC_JoinClass
  }

  package "Document Management" {
    usecase "Upload document" as UC_Upload
    usecase "Choose document visibility" as UC_Visibility
    usecase "Validate target classes" as UC_ValidateClasses
    usecase "Parse, chunk and embed" as UC_Index
    usecase "Approve or reject document" as UC_Review
  }

  package "Learning" {
    usecase "Read authorized document" as UC_Read
    usecase "Generate Study Assist" as UC_GenerateAssist
    usecase "View Study Assist" as UC_ViewAssist
  }

  package "RAG Chat and Quota" {
    usecase "Start document chat" as UC_StartChat
    usecase "Open chat history" as UC_OpenChat
    usecase "Ask question" as UC_Ask
    usecase "Authorize document scope" as UC_Authorize
    usecase "Reserve monthly user quota" as UC_Quota
    usecase "Retrieve selected document chunks" as UC_Retrieve
    usecase "Generate answer with citations" as UC_Answer
  }

  package "Subscription" {
    usecase "View and select plan" as UC_Plan
  }
}

Admin --> UC_ManageCatalog
Admin --> UC_ManageClasses
Admin --> UC_Review
Teacher --> UC_Upload
Teacher --> UC_GenerateAssist
Teacher --> UC_Read
Student --> UC_JoinClass
Student --> UC_Read
Student --> UC_ViewAssist
Student --> UC_StartChat
Student --> UC_OpenChat
Student --> UC_Ask
Student --> UC_Plan

UC_Upload .> UC_Visibility : <<include>>
UC_Visibility .> UC_ValidateClasses : <<include>>\nwhen class-restricted
UC_Upload .> UC_Index : <<include>>
UC_Read .> UC_Authorize : <<include>>
UC_ViewAssist .> UC_Authorize : <<include>>
UC_StartChat .> UC_Authorize : <<include>>
UC_OpenChat .> UC_Authorize : <<include>>
UC_Ask .> UC_Authorize : <<include>>
UC_Ask .> UC_Quota : <<include>>
UC_Ask .> UC_Retrieve : <<include>>
UC_Ask .> UC_Answer : <<include>>

Gemini --> UC_Index
Gemini --> UC_GenerateAssist
Gemini --> UC_Answer
Mongo --> UC_Authorize
Mongo --> UC_Quota
Mongo --> UC_Retrieve

note right of UC_Visibility
subject-wide: all active classes in subject
class-restricted: selected active classes only
end note

note right of UC_Quota
Account-wide UTC calendar month
Free 50 / Plus 300 / Pro 1000
Plan changes do not reset usage
end note

note right of UC_Retrieve
Retrieval remains scoped to the
single selected document.
end note
@enduml
