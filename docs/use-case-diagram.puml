@startuml
left to right direction
actor Admin
actor Teacher
actor Student
actor "Gemini API" as Gemini
actor "SMTP/Gmail" as SMTP

rectangle "EduSmart Subject-only RAG" {
  usecase "Manage accounts" as Accounts
  usecase "Manage subjects" as Subjects
  usecase "Assign teachers" as Assign
  usecase "Manage all documents" as AdminDocs
  usecase "View assigned subjects" as AssignedSubjects
  usecase "Upload and manage own documents" as TeacherDocs
  usecase "View active subjects and ready documents" as Browse
  usecase "Ask document-grounded questions" as Chat
  usecase "Process document" as Process
  usecase "Generate RAG answer and citations" as Rag
  usecase "Queue and retry email notifications" as Email
  usecase "View email status and audit logs" as Observability
  usecase "Record document audit log" as Audit
}

Admin --> Accounts
Admin --> Subjects
Admin --> Assign
Admin --> AdminDocs
Admin --> Chat
Admin --> Observability
Teacher --> AssignedSubjects
Teacher --> TeacherDocs
Teacher --> Chat
Student --> Browse
Student --> Chat
TeacherDocs .> Process : <<include>>
TeacherDocs .> Audit : <<include>>
Accounts .> Email : <<include>>
Assign .> Email : <<include>>
Email --> SMTP
Process --> Gemini
Chat .> Rag : <<include>>
Rag --> Gemini
@enduml
