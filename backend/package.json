{
  "name": "se1939-rag-chatbot-backend",
  "version": "1.0.0",
  "description": "Express TypeScript backend for the SE1939 RAG chatbot.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:subject-only": "tsx src/utils/migrateSubjectOnly.ts",
    "migrate:subject-only:dry": "tsx src/utils/migrateSubjectOnly.ts --dry-run",
    "email:test": "tsx src/utils/testEmail.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.8.0",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "officeparser": "^5.1.1",
    "pdf-parse": "^1.1.1",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
