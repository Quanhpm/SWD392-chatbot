    {
      "name": "3. Document Management",
      "item": [
        {
          "name": "Upload Document (Teacher Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson.document && responseJson.document._id) {",
                  "    pm.globals.set(\"document_id\", responseJson.document._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "subjectId",
                  "value": "{{subject_id}}",
                  "type": "text"
                },
                {
                  "key": "visibility",
                  "value": "subject-wide",
                  "type": "text"
                },
                {
                  "key": "classIds",
                  "value": "[]",
                  "type": "text"
                },
                {
                  "key": "chapter",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "chapterTitle",
                  "value": "RAG Architectures and JWT Security Models",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/documents/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "upload"
              ]
            }
          },
          "response": []
        },
